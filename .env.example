# ══════════════════════════════════════════
# County Finance — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════

# ── App ──
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Database (Railway MySQL) ──
DATABASE_URL=mysql://root:password@localhost:3306/county

# ── Auth (Clerk) ──
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Storage (Cloudflare R2) ──
# Get these from https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=county-assets
R2_PUBLIC_URL=https://assets.county.finance

# ── AI (Anthropic Claude) ──
# Get from https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
AI_MODEL=claude-haiku-4-5-20251001
AI_SMART_MODEL=claude-sonnet-4-6
AI_VISION_MODEL=claude-sonnet-4-6

# ── Payments (Scalev) ──
SCALEV_WEBHOOK_SECRET=your_scalev_webhook_secret

# ── Security ──
# Generate with: openssl rand -hex 32
JWT_SECRET=your_random_256bit_hex_string
ADMIN_SECRET_KEY=your_admin_secret_key

# ── Feature Flags ──
ENABLE_AI=true
ENABLE_RECEIPT_SCAN=true
