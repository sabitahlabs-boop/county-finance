# ══════════════════════════════════════════
# County Finance — .env.local
# Fill in these values and rename to .env
# ══════════════════════════════════════════

# ── App ──
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Database (Railway MySQL) ──
# Copy from Railway Dashboard > MySQL service > Variables > DATABASE_URL
DATABASE_URL=

# ── Auth (Clerk) ──
# From: https://dashboard.clerk.com > API Keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ── Storage (Cloudflare R2) ──
# From: https://dash.cloudflare.com > R2 > Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=county-assets
R2_PUBLIC_URL=

# ── AI (Anthropic Claude) ──
# From: https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
AI_SMART_MODEL=claude-sonnet-4-6
AI_VISION_MODEL=claude-sonnet-4-6

# ── Payments (Scalev) ──
# Scalev dashboard webhook settings — create secret, set as this value
# Scalev will POST to: {APP_URL}/api/scalev/webhook after successful payment
SCALEV_WEBHOOK_SECRET=

# ── Admin ──
# Secret key for admin-only endpoints (e.g., manual upgrade user to Pro)
# Generate with: openssl rand -hex 24
ADMIN_SECRET_KEY=

# ── Session ──
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Feature Flags ──
ENABLE_AI=true
ENABLE_RECEIPT_SCAN=true
